# Safe Windows + uv local demo profile.
# Copy this file to ./app.env for local smoke tests and demos.
# Replace CHANGE_ME values before connecting to real services.

FLASK_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
YOLO_TELEMETRY=false

# Local paths
MODEL_PATH=.\model\biaochezhajiev2.pt
MODEL_PATH_GENERAL=.\model\yolov8s-worldv2.pt
MOBILECLIP_TS_PATH=.\model\mobileclip_blt.ts
CLIP_VIT_B32_PATH=.\model\ViT-B-32.pt
ORACLE_IC_DIR=.\instantclient_11_2
OUTPUT_DIR=.\output
RESULTS_DIR=.\output\_results
SQLITE_DB_PATH=.\jobs.sqlite3
DATASETS_DIR=.\datasets
TRAIN_RUNS_DIR=.\train_runs
UPLOAD_TEMP_DIR=.\upload_tmp
FACE_MODEL_DET=.\model\det_10g.onnx
FACE_MODEL_REC=.\model\w600k_r50.onnx
FACE_DATA_DIR=.\face_data
FACE_SQL_QUERY_PATH=.\face_library.sql

# Demo-safe switches. Keep external integrations mocked unless you need real calls.
DISPATCH_MOCK_MODE=true
FACE_SQL_ENABLED=false

# Oracle placeholders. Keep passwords out of source control.
ORACLE_HOST=oracledb.example.com
ORACLE_PORT=1521
ORACLE_SERVICE=yfgxpt
ORACLE_USER=yfzagk
ORACLE_PASSWORD=CHANGE_ME
SMS_ORACLE_HOST=oracledb.example.com
SMS_ORACLE_PORT=1521
SMS_ORACLE_SERVICE=yfgxpt
SMS_ORACLE_USER=dxpt
SMS_ORACLE_PASSWORD=CHANGE_ME

# Face library SQL placeholders, only used when FACE_SQL_ENABLED=true.
FACE_SQL_HOST=
FACE_SQL_PORT=5432
FACE_SQL_DB=
FACE_SQL_USER=
FACE_SQL_PASSWORD=
FACE_SIMILARITY_THR=0.35
FACE_MATCH_TOP_K=5
FACE_BLUR_THRESH=60

# Dispatch platform placeholders, only used when DISPATCH_MOCK_MODE=false.
DISPATCH_AUTH_URL=http://dispatch.example.com/oauth/token
DISPATCH_TASK_URL=http://dispatch.example.com/api/receiveAndCreateRw
DISPATCH_CLIENT_ID=CHANGE_ME
DISPATCH_CLIENT_SECRET=CHANGE_ME
DISPATCH_GRANT_TYPE=password
DISPATCH_RWYID=CHANGE_ME
DISPATCH_SJCSLY=multi-rider
DISPATCH_QSSX=06
DISPATCH_FKSX=08
DISPATCH_GJDQ=CHN
DISPATCH_ZJLX=111
DISPATCH_XFDW=
DISPATCH_YWFZR=
DISPATCH_YWFZRLXDH=
DISPATCH_QUEUE_LIMIT=100
DISPATCH_SMS_DEFAULT_MOBILE=
DISPATCH_SMS_USERID=CHANGE_ME
DISPATCH_SMS_PASSWORD=CHANGE_ME
DISPATCH_SMS_USERPORT=0006

# Runtime tuning
MAX_WORKERS=8
MAX_UPLOAD_BYTES=1073741824
CONF_THRESH=0.7
BATCH_SIZE=8
IMGSZ=640
VIDEO_FRAME_INTERVAL=5
JOB_RETENTION_DAYS=0
